{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-parametric-architect.dev/design-intent/1.0.0.json",
  "title": "AI Parametric Architect Design Intent 1.0.0",
  "description": "Provider-neutral architectural requirements before geometry generation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["building_type", "area"],
  "oneOf": [
    { "required": ["rooms"] },
    { "required": ["room_requirements"] }
  ],
  "properties": {
    "building_type": {
      "$ref": "#/$defs/CanonicalToken"
    },
    "area": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/CanonicalToken"
      }
    },
    "room_requirements": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/RoomRequirement"
      }
    },
    "orientation": {
      "enum": ["north", "south", "east", "west", null]
    },
    "spatial_constraints": {
      "type": "array",
      "maxItems": 128,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/SpatialConstraint"
      }
    }
  },
  "$defs": {
    "CanonicalToken": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "RoomRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["room_type", "count"],
      "properties": {
        "room_type": {
          "$ref": "#/$defs/CanonicalToken"
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        }
      }
    },
    "SpatialConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_room_type",
        "relation",
        "target_room_type",
        "required"
      ],
      "properties": {
        "source_room_type": {
          "$ref": "#/$defs/CanonicalToken"
        },
        "relation": {
          "type": "string",
          "enum": [
            "adjacent_to",
            "near",
            "separated_from",
            "north_of",
            "south_of",
            "east_of",
            "west_of"
          ]
        },
        "target_room_type": {
          "$ref": "#/$defs/CanonicalToken"
        },
        "required": {
          "type": "boolean"
        }
      }
    }
  }
}
