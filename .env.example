# No secrets or external services are required for the default showcase.
SHOWCASE_BACKEND_HOST=127.0.0.1
SHOWCASE_BACKEND_PORT=8000
SHOWCASE_FRONTEND_HOST=127.0.0.1
SHOWCASE_FRONTEND_PORT=3000

# Optional intent-only adapter example configuration. The benchmark CLI still requires
# an explicit --openai-model flag. Keep OPENAI_API_KEY in a secret store; do not commit it.
OPENAI_MODEL=
